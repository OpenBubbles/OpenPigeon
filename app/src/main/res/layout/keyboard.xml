<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_wordhunt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 1"
            android:scaleType="centerCrop"
            android:src="@drawable/wordhunt" />

        <ImageView
            android:id="@+id/btn_basketball"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 2"
            android:scaleType="centerCrop"
            android:src="@drawable/basketball" />

        <ImageView
            android:id="@+id/btn_game_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 3"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />

        <ImageView
            android:id="@+id/btn_game_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 4"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_game_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 5"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />

        <ImageView
            android:id="@+id/btn_game_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 6"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />

        <ImageView
            android:id="@+id/btn_game_7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 7"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />

        <ImageView
            android:id="@+id/btn_game_8"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="Game 8"
            android:scaleType="centerCrop"
            android:src="@drawable/empty" />
    </LinearLayout>
</LinearLayout>
